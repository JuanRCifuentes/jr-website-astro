---
interface Props {
  as?: string
  decorate?: boolean
  class?: string
  dateTime?: string
}

const { as: Tag = 'p', decorate = false, class: className, dateTime } = Astro.props
---

{Tag === 'time' ? (
  <time
    datetime={dateTime}
    class:list={[
      className,
      'relative z-10 order-first mb-3 flex items-center text-sm text-zinc-400 dark:text-zinc-500',
      decorate && 'pl-3.5',
    ]}
  >
    {decorate && (
      <span class="absolute inset-y-0 left-0 flex items-center" aria-hidden="true">
        <span class="h-4 w-0.5 rounded-full bg-zinc-200 dark:bg-zinc-500"></span>
      </span>
    )}
    <slot />
  </time>
) : (
  <p
    class:list={[
      className,
      'relative z-10 order-first mb-3 flex items-center text-sm text-zinc-400 dark:text-zinc-500',
      decorate && 'pl-3.5',
    ]}
  >
    {decorate && (
      <span class="absolute inset-y-0 left-0 flex items-center" aria-hidden="true">
        <span class="h-4 w-0.5 rounded-full bg-zinc-200 dark:bg-zinc-500"></span>
      </span>
    )}
    <slot />
  </p>
)}
